# Copy this file to ".env" and fill in real values. ".env" is git-ignored.
# The .env file powers BOTH local dev (npm run dev) and the ingestion script.

# Which provider generates chat replies: "gemini" or "anthropic" (default: gemini).
# Embeddings ALWAYS use Gemini regardless of this setting (Anthropic has no
# embeddings API), so GEMINI_API_KEY is required either way.
CHAT_PROVIDER=gemini

# Google Gemini API key (required — used for embeddings, and for chat when CHAT_PROVIDER=gemini)
GEMINI_API_KEY=

# Anthropic API key (required only when CHAT_PROVIDER=anthropic; uses Claude Haiku)
ANTHROPIC_API_KEY=

# Supabase project (Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://flkmbqwtiytxbagahdus.supabase.co
# The SECRET service_role / secret key, NOT the publishable key. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Secret salt for hashing the client device id before logging it (HMAC-SHA256).
# Any long random string. If unset, device_hash is stored null (raw id is never stored).
# Set this in Vercel Production too. Server-side only — never PUBLIC_-prefixed.
DEVICE_ID_SALT=
