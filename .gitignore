node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Windows-specific files
Thumbs.db

# editor/vault tooling (not part of the site)
.obsidian/
# Ignore local .claude tooling (launch.json, settings.local.json, …) but version
# the skills and agents so they travel with the repo. Note: the parent dir must be
# matched with `.claude/*` (not `.claude/`) for the negations below to take effect —
# git can't re-include a path whose parent directory is itself excluded.
.claude/*
!.claude/skills/
!.claude/agents/

# .env variants — ignore all .env files EXCEPT the tracked example template.
# The `!.env.example` negation must come AFTER the broad `.env*` rule, otherwise
# that rule re-ignores it (later patterns win in gitignore).
.env.*
.vercel
.env*
!.env.example

# local scratch scripts (not part of the site)
test_chat.*

# pdf2md staging: raw, unreviewed PDF extractions pending human review + promotion
# into knowledge/. Transient scratch (may hold third-party PDF content) — never versioned.
knowledge/_staging/
# transient PDFs dropped into the root for `npm run pdf2md` (the script deletes them
# after conversion; this guards against a failed run leaving one committed)
/*.pdf

# personal git cheat sheet (not part of the site)
GIT_CHEATSHEET.md
