---
// Site footer — quiet, editorial, hairline top rule (per the design system).
const year = new Date().getUTCFullYear();
---

<footer class="site-footer">
  <div class="wrapper site-footer__inner">
    <div class="site-footer__brand">
      <div class="site-footer__mark">Bobby Muljono</div>
      <p>Senior Data Analyst who builds with AI.</p>
      <p class="site-footer__copy">&copy; {year}</p>
    </div>

    <div class="site-footer__cols">
      <div class="site-footer__col">
        <div class="site-footer__head">Site</div>
        <a href="/projects/">Work</a>
        <a href="/#contact">Contact</a>
      </div>
      <div class="site-footer__col">
        <div class="site-footer__head">Elsewhere</div>
        <a href="https://github.com/bobbymuljono" rel="me">GitHub</a>
        <a href="https://www.linkedin.com/in/bobbymul" rel="me">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
  }

  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-7);
    padding-block: var(--space-7) var(--space-8);
  }

  .site-footer__brand {
    max-width: 320px;
  }

  .site-footer__mark {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
  }

  .site-footer__brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }

  .site-footer__copy {
    margin-top: var(--space-4) !important;
  }

  .site-footer__cols {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .site-footer__head {
    font-family: var(--font-label);
    font-style: italic;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-normal);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .site-footer__col a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .site-footer__col a:hover {
    color: var(--color-accent);
  }
</style>
