---
// Site footer — minimal & editorial: brand + tagline on the left, external links on the
// right. Work/Contact live in the (sticky) header, so the footer intentionally does NOT
// repeat them — it only carries the off-site links and the copyright line.
const year = new Date().getUTCFullYear();
---

<footer class="site-footer">
  <div class="wrapper site-footer__inner">
    <div class="site-footer__brand">
      <div class="site-footer__mark">Bobby Muljono</div>
      <p>Senior Data Analyst who builds with AI.</p>
      <p class="site-footer__copy">&copy; {year}</p>
    </div>

    <nav aria-label="Elsewhere" class="site-footer__links">
      <a href="https://github.com/bobbymuljono" rel="me">GitHub</a>
      <span aria-hidden="true" class="site-footer__sep">&middot;</span>
      <a href="https://www.linkedin.com/in/bobbymul" rel="me">LinkedIn</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
  }

  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: var(--space-6);
    padding-block: var(--space-7) var(--space-8);
  }

  .site-footer__brand {
    max-width: 320px;
  }

  .site-footer__mark {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
  }

  .site-footer__brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }

  .site-footer__copy {
    margin-top: var(--space-4) !important;
  }

  .site-footer__links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
  }

  .site-footer__links a {
    color: var(--color-text);
    text-decoration: none;
  }

  .site-footer__links a:hover {
    color: var(--color-accent);
  }

  .site-footer__sep {
    color: var(--color-text-muted);
  }
</style>
