---
// Site navigation — wordmark + section links + primary CTA, per the design system.
// Chat / Writing are Phase 2, so the nav wires only real destinations for now.
const { pathname } = Astro.url;
// 'Contact' is intentionally omitted — the 'Get in touch' button below points to the
// same #contact anchor, so a separate text link would be redundant.
const navLinks = [
  { href: '/projects/', label: 'Work' },
];
const isActive = (href: string) =>
  href === '/projects/' ? pathname.startsWith('/projects') : false;
---

<header class="site-header">
  <div class="wrapper site-header__inner">
    <a href="/" class="site-header__mark">Bobby Muljono</a>
    <nav aria-label="Primary" class="site-header__nav">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={['site-header__link', { 'is-active': isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a href="/#contact" class="button button--primary button--sm">Get in touch</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    /* Opaque stone — the design system bans blur/translucency, so the sticky bar
       is a solid surface, not a glass one. */
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-block: var(--space-5);
  }

  .site-header__mark {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-decoration: none;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .site-header__link {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .site-header__link:hover {
    color: var(--color-accent);
  }

  .site-header__link.is-active {
    color: var(--color-accent);
    font-weight: var(--weight-semibold);
    border-bottom-color: var(--color-accent);
  }
</style>
