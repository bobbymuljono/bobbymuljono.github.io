---
interface Props {
  slug: string;
  title: string;
  description: string;
  techStack: string[];
  kind?: string;
}

const { slug, title, description, techStack, kind } = Astro.props;
---

<a href={`/projects/${slug}/`} class="card card--interactive project-row" data-reveal>
  <div class="project-row__body">
    {kind && <span class="eyebrow">{kind}</span>}
    <h3>{title}</h3>
    <p>{description}</p>
    <ul class="tag-list">
      {techStack.map((tech) => <li class="tag">{tech}</li>)}
    </ul>
  </div>
  <span class="project-row__cta">Read case study &rarr;</span>
</a>

<style>
  .project-row {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .project-row__body {
    flex: 1;
    min-width: min(300px, 100%);
  }

  .project-row h3 {
    font-size: var(--text-2xl);
    margin: var(--space-2) 0 var(--space-2);
  }

  .project-row p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
    max-width: 60ch;
  }

  .project-row__cta {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--color-accent);
    white-space: nowrap;
  }
</style>
