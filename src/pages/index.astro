---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatBot from '../components/ChatBot.astro';

const featured = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const heroTags = ['Presto SQL', 'Python', 'LangChain', 'LLM integration', 'A/B testing', 'Data Visualization'];
---

<BaseLayout
  title="Bobby Muljono"
  description="Senior Data Analyst building with AI — RAG chatbots, multi-agent workflows, and analytics."
>
  <!-- Hero -->
  <section class="hero" data-reveal>
    <div class="hero__intro">
      <h1>I build with AI, and I storytell with data for a living.</h1>
      <p class="hero__lead">
        I'm Bobby — a Senior Data Analyst, with 6+ years in SQL, dashboarding,
        and data analytics. These days that expertise is evolving into building the AI
        that does it with me: RAG chatbots, automated SQL execution, and automated
        insight and visualization generation.
      </p>
    </div>
    <div class="hero__portrait">
      <img
        src="/bobby-headshot.png"
        alt="Bobby Muljono"
        width="896"
        height="1036"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero__body">
      <!-- Buttons share one row: See my work (primary) + Get in touch + Chat with Bobby AI -->
      <div class="hero__cta">
        <a class="button button--primary" href="/projects/">See my work</a>
        <a class="button button--secondary" href="#contact">Get in touch</a>
        <ChatBot />
      </div>
      <ul class="tag-list hero__tags">
        {heroTags.map((tag) => <li class="tag">{tag}</li>)}
      </ul>
    </div>
  </section>

  <!-- Experience — minimalist progression list (inspired by henrylin.io) -->
  <section class="experience" data-reveal>
    <span class="eyebrow">Experience</span>
    <ul class="exp-list">
      <li class="exp">
        <div class="exp__head">
          <h3 class="exp__company">Shopee</h3>
          <span class="exp__years">2020 &mdash; Present</span>
        </div>
        <p class="exp__role">Senior Data Analyst</p>
        <p class="exp__note">Building analytical solutions with AI</p>
      </li>

      <li class="exp">
        <div class="exp__head">
          <h3 class="exp__company">ISS Facility Services</h3>
          <span class="exp__years">2019 &mdash; 2020</span>
        </div>
        <p class="exp__role">Data Analyst</p>
        <p class="exp__note">Drawing insights from data</p>
      </li>

      <li class="exp">
        <div class="exp__head">
          <h3 class="exp__company">First Code Academy</h3>
          <span class="exp__years">2017</span>
        </div>
        <p class="exp__role">STEM Course Facilitator</p>
        <p class="exp__note">Teaching kids how to code</p>
      </li>
    </ul>
  </section>

  <!-- Selected work -->
  {
    featured.length > 0 && (
      <section class="selected" data-reveal>
        <div class="selected__head">
          <span class="eyebrow">Selected work</span>
          <a href="/projects/" class="selected__all">All projects &rarr;</a>
        </div>
        <div class="selected__grid">
          {featured.map((p) => (
            <a href={`/projects/${p.id}/`} class="card card--interactive project-preview">
              {p.data.kind && <span class="eyebrow">{p.data.kind}</span>}
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <ul class="tag-list">
                {p.data.techStack.map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- Contact -->
  <section id="contact" class="contact" data-reveal>
    <span class="eyebrow">Contact</span>
    <h2>Let's talk.</h2>
    <p class="contact__lead">
      Building something at the seam of analytics and AI, or just want to compare notes?
      I'm happy to hear from you.
    </p>
    <div class="contact__actions">
      <a class="button button--secondary" href="https://github.com/bobbymuljono">GitHub</a>
      <a class="button button--secondary" href="https://www.linkedin.com/in/bobbymul">LinkedIn</a>
    </div>
  </section>
</BaseLayout>

<style>
  section {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  section:first-child {
    border-top: none;
  }

  /* Hero — two-column grid: text (intro over body) left, portrait spanning right. */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    grid-template-areas:
      "intro   portrait"
      "body    portrait";
    column-gap: var(--space-8);
    align-items: center;
    padding-top: var(--space-9);
  }

  .hero__intro {
    grid-area: intro;
    max-width: 560px;
  }

  .hero__body {
    grid-area: body;
    max-width: 560px;
  }

  .hero h1 {
    font-size: var(--text-4xl);
    margin: 18px 0 20px;
  }

  .hero__lead {
    font-size: var(--text-lg);
    line-height: 1.55;
    max-width: 58ch;
    margin: 0 0 var(--space-3);
  }

  .hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-5);
    flex-wrap: wrap;
  }

  /* ChatBot renders a wrapper div; make it transparent so its launch button
     sits in the CTA flex row alongside the other two buttons. */
  .hero__cta :global(.bobbychat) {
    display: contents;
  }

  .hero__tags {
    margin-top: var(--space-6);
  }

  /* Portrait panel — sage-wash box, photo fills it and fades gently into the sage at the bottom. */
  .hero__portrait {
    grid-area: portrait;
    align-self: center;
    width: 320px;
    height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--sage-wash);
    border: 1px solid var(--color-border);
    border-bottom: none; /* let the faded photo dissolve into the sage cleanly */
  }

  .hero__portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    /* Subtle bottom fade only — opaque to 80%, then dissolves into the sage panel. */
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 80%, rgba(0, 0, 0, 0) 100%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 80%, rgba(0, 0, 0, 0) 100%);
  }

  /* Experience — minimalist progression list (inspired by henrylin.io):
     company + year range on one line, italic-serif role, muted one-liner.
     Whitespace-separated, no dividers. */
  .exp-list {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-7);
  }

  .exp__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .exp__company {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .exp__years {
    flex-shrink: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-snug);
    font-variant-numeric: tabular-nums;
  }

  .exp__role {
    font-family: var(--font-label);
    font-style: italic;
    color: var(--color-accent);
    font-size: var(--text-lg);
    margin: var(--space-1) 0 0;
  }

  .exp__note {
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }

  /* Selected work */
  .selected__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-5);
    gap: var(--space-4);
  }

  .selected__all {
    font-size: var(--text-sm);
    text-decoration: none;
    white-space: nowrap;
  }

  .selected__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .project-preview h3 {
    font-size: var(--text-xl);
    margin: var(--space-2) 0 var(--space-3);
  }

  .project-preview p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  /* Contact */
  .contact h2 {
    font-size: var(--text-3xl);
    margin: var(--space-3) 0 var(--space-3);
  }

  .contact__lead {
    color: var(--color-text-muted);
    max-width: 54ch;
  }

  .contact__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  @media (max-width: 52rem) {
    .selected__grid {
      grid-template-columns: 1fr;
    }

    /* Experience: year range drops below the company name instead of sitting inline. */
    .exp__head {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }

    .exp__company {
      font-size: var(--text-xl);
    }

    /* Stack to a single column: intro, then photo, then the buttons/tags. */
    .hero {
      grid-template-columns: 1fr;
      grid-template-areas:
        "intro"
        "portrait"
        "body";
      row-gap: var(--space-5);
    }

    .hero__portrait {
      width: 100%;
      /* Cap width so the panel stays a portrait shape (not a wide letterbox that
         crops the face) on wider stacked viewports; centered per spec. */
      max-width: 320px;
      height: 380px; /* concrete height so the photo's object-fit: cover resolves */
      max-height: 380px;
      justify-self: center;
    }
  }
</style>
